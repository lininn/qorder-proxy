{
  "name": "qorder-proxy",
  "version": "2.0.0",
  "description": "Local OpenAI / Anthropic compatible proxy for Qoder CLI - with daemon mode and web setup",
  "main": "lib/server.js",
  "bin": {
    "qorder-proxy": "./bin/qorder-proxy.js"
  },
  "files": [
    "bin/",
    "lib/",
    "clean/",
    "public/",
    "public-setup/",
    "scripts/",
    "opencode.json",
    "CHANGELOG.md",
    "README.md",
    "SECURITY.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "start": "node bin/qorder-proxy.js run",
    "dev": "node bin/qorder-proxy.js run",
    "test": "node --test",
    "smoke": "node scripts/smoke.js",
    "smoke:full": "node scripts/smoke.js --full"
  },
  "keywords": [
    "qorder-proxy",
    "qoder",
    "qoder-cn",
    "qodercn",
    "openai-compatible",
    "anthropic-compatible",
    "local-adapter",
    "compatibility",
    "protocol-research",
    "streaming",
    "tool-calls",
    "proxy-server",
    "daemon",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lininn/qorder-proxy"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "preferGlobal": true
}
